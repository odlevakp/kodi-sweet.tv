# Settings help text (descriptions shown in the footer)
msgctxt "#30900"
msgid "General settings: account pairing and stream quality."
msgstr "Všeobecné nastavenia: párovanie účtu a kvalita streamu."

msgctxt "#30901"
msgid "Start the device pairing flow. You will be shown a code to enter at sweet.tv -> My Devices."
msgstr "Spustí proces párovania zariadenia. Zobrazí sa vám kód, ktorý zadáte na sweet.tv -> Moje zariadenia."

msgctxt "#30902"
msgid "Logout from sweet.tv and clear stored credentials. You will need to re-pair to use the addon again."
msgstr "Odhlási vás zo sweet.tv a vymaže uložené prihlasovacie údaje. Pre ďalšie použitie doplnku bude potrebné opätovné spárovanie."

msgctxt "#30903"
msgid "Cap the maximum HLS variant bitrate the addon will request. Lower values use less bandwidth at the cost of quality."
msgstr "Obmedzí maximálny bitrate HLS variantu, ktorý si doplnok vyžiada. Nižšie hodnoty šetria pripojenie na úkor kvality."

msgctxt "#30904"
msgid "Channel and EPG configuration."
msgstr "Konfigurácia kanálov a EPG."

msgctxt "#30905"
msgid "When enabled, channels marked as adult by sweet.tv (18+ category) appear in listings and the TV guide."
msgstr "Ak je zapnuté, kanály označené sweet.tv ako pre dospelých (kategória 18+) sa zobrazia v zoznamoch a v TV programe."

msgctxt "#30906"
msgid "How many days of EPG data to fetch from sweet.tv when IPTV Manager refreshes. More days = larger payload and slower refresh."
msgstr "Koľko dní EPG dát stiahnuť zo sweet.tv pri obnove cez IPTV Manager. Viac dní znamená väčšie množstvo dát a pomalšiu obnovu."

msgctxt "#30907"
msgid "Stream playback behaviour."
msgstr "Správanie pri prehrávaní streamu."

msgctxt "#30909"
msgid "Tell sweet.tv to release the stream slot when playback stops. If disabled, slots leak until the server times them out, which can trigger 'too many devices' errors."
msgstr "Po zastavení prehrávania povie sweet.tv, aby uvoľnil slot streamu. Ak je vypnuté, sloty zostávajú obsadené až do timeoutu na serveri, čo môže spôsobiť chybu 'príliš veľa zariadení'."

msgctxt "#30910"
msgid "Advanced settings: device management and subscription info."
msgstr "Pokročilé nastavenia: správa zariadení a informácie o predplatnom."

msgctxt "#30911"
msgid "Open the list of devices currently registered to your sweet.tv account. You can remove devices to free up slots."
msgstr "Otvorí zoznam zariadení aktuálne registrovaných k vášmu sweet.tv účtu. Zariadenia môžete odstrániť pre uvoľnenie slotov."

msgctxt "#30912"
msgid "Show details about your active sweet.tv subscription."
msgstr "Zobrazí informácie o vašom aktívnom sweet.tv predplatnom."

msgctxt "#30813"
msgid "Show Movies Not in Subscription"
msgstr "Zobraziť filmy mimo predplatného"
