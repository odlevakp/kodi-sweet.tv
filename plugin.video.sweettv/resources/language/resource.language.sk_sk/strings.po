# Pairing
msgctxt "#30200"
msgid "Pair Device"
msgstr "Spárovať zariadenie"

msgctxt "#30201"
msgid "Sweet.TV - Device Pairing"
msgstr "Sweet.TV - Párovanie zariadenia"

msgctxt "#30202"
msgid "Your pairing code is: [B]{code}[/B][CR][CR]Go to sweet.tv, log in to your account,[CR]navigate to My Devices, enter this code,[CR]and click Activate.[CR][CR]Waiting for pairing..."
msgstr "Váš párovací kód je: [B]{code}[/B][CR][CR]Prejdite na sweet.tv, prihláste sa do svojho účtu,[CR]otvorte sekciu Moje zariadenia, zadajte tento kód[CR]a kliknite na Aktivovať.[CR][CR]Čakám na spárovanie..."

msgctxt "#30203"
msgid "Already paired. Do you want to re-pair?"
msgstr "Zariadenie je už spárované. Chcete ho spárovať znova?"

msgctxt "#30204"
msgid "Failed to get pairing code. Please try again."
msgstr "Nepodarilo sa získať párovací kód. Skúste to znova."

msgctxt "#30205"
msgid "Device paired successfully!"
msgstr "Zariadenie bolo úspešne spárované!"

msgctxt "#30206"
msgid "Pairing timed out. Please try again."
msgstr "Vypršal čas párovania. Skúste to znova."

msgctxt "#30207"
msgid "Are you sure you want to unpair this device?"
msgstr "Naozaj chcete zrušiť spárovanie tohto zariadenia?"

msgctxt "#30208"
msgid "Device unpaired successfully."
msgstr "Spárovanie zariadenia bolo zrušené."

msgctxt "#30209"
msgid "Not logged in. Please pair your device first."
msgstr "Neprihlásený. Najprv spárujte svoje zariadenie."

