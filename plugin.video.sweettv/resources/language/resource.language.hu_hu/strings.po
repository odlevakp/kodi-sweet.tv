# Pairing
msgctxt "#30200"
msgid "Pair Device"
msgstr "Eszköz párosítása"

msgctxt "#30201"
msgid "Sweet.TV - Device Pairing"
msgstr "Sweet.TV - Eszköz párosítása"

msgctxt "#30202"
msgid "Your pairing code is: [B]{code}[/B][CR][CR]Go to sweet.tv, log in to your account,[CR]navigate to My Devices, enter this code,[CR]and click Activate.[CR][CR]Waiting for pairing..."
msgstr "A párosítási kód: [B]{code}[/B][CR][CR]Lépjen a sweet.tv oldalra, jelentkezzen be,[CR]navigáljon az Eszközeim menüpontba, adja meg ezt a kódot,[CR]és kattintson az Aktiválás gombra.[CR][CR]Várakozás a párosításra..."

msgctxt "#30203"
msgid "Already paired. Do you want to re-pair?"
msgstr "Már párosítva. Szeretné újra párosítani?"

msgctxt "#30204"
msgid "Failed to get pairing code. Please try again."
msgstr "Nem sikerült megkapni a párosítási kódot. Kérjük, próbálja újra."

msgctxt "#30205"
msgid "Device paired successfully!"
msgstr "Az eszköz sikeresen párosítva!"

msgctxt "#30206"
msgid "Pairing timed out. Please try again."
msgstr "A párosítás időtúllépés miatt megszakadt. Kérjük, próbálja újra."

msgctxt "#30207"
msgid "Are you sure you want to unpair this device?"
msgstr "Biztosan szeretné leválasztani ezt az eszközt?"

msgctxt "#30208"
msgid "Device unpaired successfully."
msgstr "Az eszköz sikeresen leválasztva."

msgctxt "#30209"
msgid "Not logged in. Please pair your device first."
msgstr "Nincs bejelentkezve. Kérjük, először párosítsa az eszközét."

