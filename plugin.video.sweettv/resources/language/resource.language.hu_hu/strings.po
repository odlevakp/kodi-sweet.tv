# Settings help text
msgctxt "#30900"
msgid "General settings: account pairing and stream quality."
msgstr "Általános beállítások: fiók párosítás és stream minőség."

msgctxt "#30901"
msgid "Start the device pairing flow. You will be shown a code to enter at sweet.tv -> My Devices."
msgstr "Eszköz párosítás indítása. Egy kódot kap, amelyet a sweet.tv -> Eszközeim menüpontban kell megadnia."

msgctxt "#30902"
msgid "Logout from sweet.tv and clear stored credentials. You will need to re-pair to use the addon again."
msgstr "Kijelentkezés a sweet.tv-ből és a tárolt hitelesítő adatok törlése. A kiegészítő újbóli használatához újra kell párosítania."

msgctxt "#30903"
msgid "Cap the maximum HLS variant bitrate the addon will request. Lower values use less bandwidth at the cost of quality."
msgstr "A kiegészítő által kért maximális HLS bitráta korlátozása. Az alacsonyabb értékek kevesebb sávszélességet használnak a minőség rovására."

msgctxt "#30904"
msgid "Channel and EPG configuration."
msgstr "Csatorna és EPG konfiguráció."

msgctxt "#30905"
msgid "When enabled, channels marked as adult by sweet.tv (18+ category) appear in listings and the TV guide."
msgstr "Ha engedélyezve van, a sweet.tv által felnőttként (18+) jelölt csatornák megjelennek a listákban és a TV műsorkalauzban."

msgctxt "#30906"
msgid "How many days of EPG data to fetch from sweet.tv when IPTV Manager refreshes. More days = larger payload and slower refresh."
msgstr "Hány nap EPG adatot töltsön le a sweet.tv-ből az IPTV Manager frissítésekor. Több nap = nagyobb adatmennyiség és lassabb frissítés."

msgctxt "#30907"
msgid "Stream playback behaviour."
msgstr "Stream lejátszási viselkedés."

msgctxt "#30909"
msgid "Tell sweet.tv to release the stream slot when playback stops. If disabled, slots leak until the server times them out, which can trigger 'too many devices' errors."
msgstr "Utasítsa a sweet.tv-t a stream slot felszabadítására, ha a lejátszás leáll. Ha ki van kapcsolva, a slotok szivárognak, amíg a szerver le nem időzíti őket, ami 'túl sok eszköz' hibákat válthat ki."

msgctxt "#30910"
msgid "Advanced settings: device management and subscription info."
msgstr "Haladó beállítások: eszközkezelés és előfizetési információk."

msgctxt "#30911"
msgid "Open the list of devices currently registered to your sweet.tv account. You can remove devices to free up slots."
msgstr "A sweet.tv fiókjához jelenleg regisztrált eszközök listájának megnyitása. Eszközöket távolíthat el a slotok felszabadításához."

msgctxt "#30912"
msgid "Show details about your active sweet.tv subscription."
msgstr "Az aktív sweet.tv előfizetés részleteinek megjelenítése."
