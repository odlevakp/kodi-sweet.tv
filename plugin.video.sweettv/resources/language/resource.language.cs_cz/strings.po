# Pairing
msgctxt "#30200"
msgid "Pair Device"
msgstr "Spárovat zařízení"

msgctxt "#30201"
msgid "Sweet.TV - Device Pairing"
msgstr "Sweet.TV - Párování zařízení"

msgctxt "#30202"
msgid "Your pairing code is: [B]{code}[/B][CR][CR]Go to sweet.tv, log in to your account,[CR]navigate to My Devices, enter this code,[CR]and click Activate.[CR][CR]Waiting for pairing..."
msgstr "Váš párovací kód je: [B]{code}[/B][CR][CR]Přejděte na sweet.tv, přihlaste se ke svému účtu,[CR]otevřete sekci Moje zařízení, zadejte tento kód[CR]a klikněte na Aktivovat.[CR][CR]Čekání na spárování..."

msgctxt "#30203"
msgid "Already paired. Do you want to re-pair?"
msgstr "Zařízení je již spárováno. Chcete jej spárovat znovu?"

msgctxt "#30204"
msgid "Failed to get pairing code. Please try again."
msgstr "Nepodařilo se získat párovací kód. Zkuste to znovu."

msgctxt "#30205"
msgid "Device paired successfully!"
msgstr "Zařízení bylo úspěšně spárováno!"

msgctxt "#30206"
msgid "Pairing timed out. Please try again."
msgstr "Vypršel čas párování. Zkuste to znovu."

msgctxt "#30207"
msgid "Are you sure you want to unpair this device?"
msgstr "Opravdu chcete zrušit spárování tohoto zařízení?"

msgctxt "#30208"
msgid "Device unpaired successfully."
msgstr "Spárování zařízení bylo zrušeno."

msgctxt "#30209"
msgid "Not logged in. Please pair your device first."
msgstr "Nejste přihlášeni. Nejprve spárujte své zařízení."

