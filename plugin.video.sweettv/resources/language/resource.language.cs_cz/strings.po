# Settings help text (descriptions shown in the footer)
msgctxt "#30900"
msgid "General settings: account pairing and stream quality."
msgstr "Obecná nastavení: párování účtu a kvalita streamu."

msgctxt "#30901"
msgid "Start the device pairing flow. You will be shown a code to enter at sweet.tv -> My Devices."
msgstr "Spustí proces párování zařízení. Zobrazí se vám kód, který zadáte na sweet.tv -> Moje zařízení."

msgctxt "#30902"
msgid "Logout from sweet.tv and clear stored credentials. You will need to re-pair to use the addon again."
msgstr "Odhlásí vás ze sweet.tv a smaže uložené přihlašovací údaje. Pro další použití doplňku bude potřeba opětovné spárování."

msgctxt "#30903"
msgid "Cap the maximum HLS variant bitrate the addon will request. Lower values use less bandwidth at the cost of quality."
msgstr "Omezí maximální bitrate HLS varianty, kterou si doplněk vyžádá. Nižší hodnoty šetří připojení na úkor kvality."

msgctxt "#30904"
msgid "Channel and EPG configuration."
msgstr "Konfigurace kanálů a EPG."

msgctxt "#30905"
msgid "When enabled, channels marked as adult by sweet.tv (18+ category) appear in listings and the TV guide."
msgstr "Pokud je zapnuto, kanály označené sweet.tv jako pro dospělé (kategorie 18+) se zobrazí v seznamech a v TV programu."

msgctxt "#30906"
msgid "How many days of EPG data to fetch from sweet.tv when IPTV Manager refreshes. More days = larger payload and slower refresh."
msgstr "Kolik dní EPG dat stáhnout ze sweet.tv při obnově přes IPTV Manager. Více dní znamená větší objem dat a pomalejší obnovu."

msgctxt "#30907"
msgid "Stream playback behaviour."
msgstr "Chování při přehrávání streamu."

msgctxt "#30909"
msgid "Tell sweet.tv to release the stream slot when playback stops. If disabled, slots leak until the server times them out, which can trigger 'too many devices' errors."
msgstr "Po zastavení přehrávání řekne sweet.tv, aby uvolnil slot streamu. Pokud je vypnuto, sloty zůstávají obsazené až do timeoutu na serveru, což může způsobit chybu 'příliš mnoho zařízení'."

msgctxt "#30910"
msgid "Advanced settings: device management and subscription info."
msgstr "Pokročilá nastavení: správa zařízení a informace o předplatném."

msgctxt "#30911"
msgid "Open the list of devices currently registered to your sweet.tv account. You can remove devices to free up slots."
msgstr "Otevře seznam zařízení aktuálně registrovaných k vašemu sweet.tv účtu. Zařízení můžete odebrat pro uvolnění slotů."

msgctxt "#30912"
msgid "Show details about your active sweet.tv subscription."
msgstr "Zobrazí informace o vašem aktivním sweet.tv předplatném."

msgctxt "#30813"
msgid "Show Movies Not in Subscription"
msgstr "Zobrazit filmy mimo předplatné"
