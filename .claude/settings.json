{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "Agent",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(make build:*)",
      "Bash(make repo:*)",
      "Bash(make repo-index:*)"
